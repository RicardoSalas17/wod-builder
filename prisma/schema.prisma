generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum BlockType {
  WARMUP
  STRENGTH
  METCON
}

model Workout {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocks    Block[]
}

model Routine {
  id          String         @id @default(cuid())
  title       String
  description String?
  focus       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  blocks      RoutineBlock[]
  sessions    LogSession[]
}

model RoutineBlock {
  id        String            @id @default(cuid())
  title     String
  position  Int
  routineId String

  routine   Routine           @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]

  @@index([routineId, position])
}

model RoutineExercise {
  id                  String        @id @default(cuid())
  name                String
  bodyPart            String?
  targetSets          Int?
  targetReps          String?
  restSeconds         Int?
  notes               String?
  loadTrackingEnabled Boolean       @default(false)
  position            Int
  routineBlockId      String

  block               RoutineBlock  @relation(fields: [routineBlockId], references: [id], onDelete: Cascade)
  loggedExercises     LogExercise[]

  @@index([routineBlockId, position])
}

model LogSession {
  id              String        @id @default(cuid())
  title           String
  performedAt     DateTime
  notes           String?
  durationMinutes Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  routineId       String?

  routine         Routine?      @relation(fields: [routineId], references: [id], onDelete: SetNull)
  exercises       LogExercise[]

  @@index([performedAt])
  @@index([routineId, performedAt])
}

model LogExercise {
  id                  String           @id @default(cuid())
  name                String
  bodyPart            String?
  notes               String?
  loadTrackingEnabled Boolean          @default(false)
  increaseWeight      Boolean          @default(false)
  position            Int
  logSessionId        String
  routineExerciseId   String?

  session             LogSession       @relation(fields: [logSessionId], references: [id], onDelete: Cascade)
  routineExercise     RoutineExercise? @relation(fields: [routineExerciseId], references: [id], onDelete: SetNull)
  sets                LogSet[]

  @@index([logSessionId, position])
}

model LogSet {
  id            String      @id @default(cuid())
  setNumber     Int
  reps          String?
  load          String?
  completed     Boolean     @default(true)
  rpe           Int?
  notes         String?
  logExerciseId String

  exercise      LogExercise @relation(fields: [logExerciseId], references: [id], onDelete: Cascade)

  @@index([logExerciseId, setNumber])
}

model Block {
  id        String    @id @default(cuid())
  type      BlockType
  title     String
  position  Int
  workoutId String

  workout   Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@index([workoutId, position])
}

model Movement {
  id       String  @id @default(cuid())
  name     String
  load     String?
  reps     String?
  notes    String?
  position Int
  blockId  String

  block    Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, position])
}
