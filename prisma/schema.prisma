generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum BlockType {
  WARMUP
  STRENGTH
  METCON
}

model Workout {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocks    Block[]
}

model Block {
  id        String    @id @default(cuid())
  type      BlockType
  title     String
  position  Int
  workoutId String

  workout   Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@index([workoutId, position])
}

model Movement {
  id       String  @id @default(cuid())
  name     String
  load     String?
  reps     String?
  notes    String?
  position Int
  blockId  String

  block    Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, position])
}
